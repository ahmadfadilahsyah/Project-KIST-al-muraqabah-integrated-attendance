<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=yes">
    <title>Daftar - Al-Muraqabah</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
<div class="card">
    <div class="logo"><h1>📿 Al-Muraqabah</h1></div>
    <h2>Daftar Akun</h2>
    <% if (error) { %>
        <div class="alert alert-error"><%= error %></div>
    <% } %>
    <form action="/register" method="post">
        <div class="form-group"><label>NIM</label><input type="text" name="nim" placeholder="Nomor Induk Mahasiswa" required></div>
        <div class="form-group"><label>Nama Lengkap</label><input type="text" name="nama" placeholder="Nama lengkap" required></div>
        <div class="form-group"><label>Password</label><input type="password" name="password" placeholder="Minimal 6 karakter" required></div>
        <div class="form-group"><label>Role</label>
            <select name="role">
                <option value="student">Mahasiswa</option>
                <option value="lecturer">Dosen</option>
            </select>
        </div>
        <button type="submit">Daftar & Langsung Masuk</button>
    </form>
    <div class="text-center mt-4">Sudah punya akun? <a href="/login">Login</a></div>
</div>
</body>
</html>