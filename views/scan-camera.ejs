<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Scan QR | Al-Muraqabah</title>
    <link rel="stylesheet" href="/css/style.css">
    <script src="https://unpkg.com/html5-qrcode"></script>
</head>
<body>
<%- include('partials/navbar') %>

<main class="main-content">
    <section class="content-card form-card text-center">
        <span class="value-badge">Shidiq dalam Kehadiran</span>
        <h2>📷 Scan QR Absensi</h2>

        <div class="islamic-message-box">
            <h3>Iman ke Aksi</h3>
            <p>Kehadiran ini bukan sekadar tercatat oleh sistem, tetapi menjadi bentuk kejujuran dan amanah dalam menuntut ilmu.</p>
        </div>

        <div class="info-box">Arahkan kamera ke QR Code yang ditampilkan dosen. Pastikan Anda melakukan scan sendiri.</div>

        <div class="form-group text-left">
            <label>Pilih Kamera</label>
            <select id="cameraSelect" class="form-control"></select>
        </div>

        <div class="button-row center">
            <button type="button" class="btn-secondary" onclick="startSelectedCamera()">Mulai Kamera</button>
            <button type="button" class="btn-secondary" onclick="switchCamera()">Ganti Kamera</button>
        </div>

        <div id="qr-reader" class="qr-reader-box"></div>
        <p id="scan-status" class="info">Menunggu kamera aktif...</p>
        <a href="/dashboard" class="btn-secondary">Kembali ke Dashboard</a>
    </section>
</main>

<script>
    const scanStatus = document.getElementById('scan-status');
    const cameraSelect = document.getElementById('cameraSelect');
    const html5QrCode = new Html5Qrcode('qr-reader');
    let cameras = [];
    let activeCameraIndex = 0;
    let isRunning = false;

    function onScanSuccess(decodedText) {
        scanStatus.innerText = 'QR berhasil dipindai. Mengalihkan ke validasi amanah...';
        html5QrCode.stop().then(() => {
            isRunning = false;
            window.location.href = decodedText;
        }).catch(() => {
            window.location.href = decodedText;
        });
    }

    function onScanFailure(error) {}

    function findBackCameraIndex(list) {
        const index = list.findIndex(camera => {
            const label = (camera.label || '').toLowerCase();
            return label.includes('back') || label.includes('rear') || label.includes('environment') || label.includes('belakang');
        });
        return index >= 0 ? index : 0;
    }

    async function startCameraByIndex(index) {
        if (!cameras.length) return;
        if (isRunning) {
            await html5QrCode.stop();
            isRunning = false;
        }

        activeCameraIndex = index;
        cameraSelect.value = String(index);
        scanStatus.innerText = 'Membuka kamera...';

        await html5QrCode.start(
            cameras[index].id,
            { fps: 10, qrbox: { width: 250, height: 250 } },
            onScanSuccess,
            onScanFailure
        );

        isRunning = true;
        scanStatus.innerText = 'Kamera aktif. Silakan scan QR dengan jujur.';
    }

    function startSelectedCamera() {
        startCameraByIndex(parseInt(cameraSelect.value || '0', 10)).catch(() => {
            scanStatus.innerText = 'Gagal membuka kamera. Izinkan akses kamera di browser.';
        });
    }

    function switchCamera() {
        if (!cameras.length) return;
        const nextIndex = (activeCameraIndex + 1) % cameras.length;
        startCameraByIndex(nextIndex).catch(() => {
            scanStatus.innerText = 'Gagal mengganti kamera.';
        });
    }

    Html5Qrcode.getCameras()
        .then(list => {
            cameras = list || [];
            if (!cameras.length) {
                scanStatus.innerText = 'Kamera tidak ditemukan.';
                return;
            }

            cameraSelect.innerHTML = cameras.map((camera, index) => {
                const label = camera.label || `Kamera ${index + 1}`;
                return `<option value="${index}">${label}</option>`;
            }).join('');

            activeCameraIndex = findBackCameraIndex(cameras);
            cameraSelect.value = String(activeCameraIndex);
            startCameraByIndex(activeCameraIndex);
        })
        .catch(() => {
            scanStatus.innerText = 'Gagal membuka kamera. Izinkan akses kamera di browser.';
        });
</script>
</body>
</html>
