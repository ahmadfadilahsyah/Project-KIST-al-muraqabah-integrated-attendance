<%
    const currentUser = typeof user !== 'undefined' ? user : null;
    const currentRole = currentUser ? currentUser.role : null;
    const isLecturer = currentRole === 'lecturer' || currentRole === 'teacher' || currentRole === 'dosen';
    const isStudent = currentRole === 'student' || currentRole === 'mahasiswa';
%>

<aside class="sidebar">
    <div class="sidebar-brand">
        <div class="brand-logo">م</div>
        <div>
            <h2>Al-Muraqabah</h2>
            <p>Iman • Shidiq • Amanah</p>
        </div>
    </div>

    <div class="islamic-sidebar-note">
        <strong>مراقبة</strong>
        <span>Kesadaran bahwa Allah selalu mengawasi setiap amanah.</span>
    </div>

    <nav class="sidebar-menu">
        <a href="/dashboard" class="sidebar-link"><span>🏠</span><span>Dashboard</span></a>

        <% if (isLecturer) { %>
            <a href="/create-session" class="sidebar-link"><span>📝</span><span>Buat Sesi</span></a>
            <a href="/gps-settings" class="sidebar-link"><span>📍</span><span>Set Lokasi</span></a>
        <% } %>

        <% if (isStudent) { %>
            <a href="/scan" class="sidebar-link"><span>📷</span><span>Scan QR</span></a>
        <% } %>

        <a href="/profile" class="sidebar-link"><span>👤</span><span>Profil</span></a>
    </nav>

    <div class="sidebar-profile">
        <div class="sidebar-avatar"><%= currentUser && currentUser.nama ? currentUser.nama.charAt(0).toUpperCase() : 'U' %></div>
        <div>
            <strong><%= currentUser ? currentUser.nama : 'User' %></strong>
            <small><%= currentUser ? currentUser.role : '-' %></small>
        </div>
    </div>

    <a href="/logout" class="logout-link">🚪 Logout</a>
</aside>

<header class="topbar">
    <div>
        <h1><%= typeof pageTitle !== 'undefined' ? pageTitle : 'Dashboard' %></h1>
        <p><%= typeof pageSubtitle !== 'undefined' ? pageSubtitle : 'Menghadirkan kejujuran akademik melalui teknologi' %></p>
    </div>

    <a href="/profile" class="topbar-profile">
        <div class="avatar"><%= currentUser && currentUser.nama ? currentUser.nama.charAt(0).toUpperCase() : 'U' %></div>
        <div>
            <strong><%= currentUser ? currentUser.nama : 'User' %></strong>
            <small><%= currentUser ? currentUser.role : '-' %></small>
        </div>
    </a>
</header>

<nav class="mobile-bottom-nav">
    <a href="/dashboard">🏠<span>Home</span></a>

    <% if (isStudent) { %>
        <a href="/scan">📷<span>Scan</span></a>
    <% } %>

    <% if (isLecturer) { %>
        <a href="/create-session">📝<span>Sesi</span></a>
        <a href="/gps-settings">📍<span>Lokasi</span></a>
    <% } %>

    <a href="/profile">👤<span>Profil</span></a>
</nav>
