<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Validasi GPS | Al-Muraqabah</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>

<%- include('partials/navbar') %>

<main class="main-content">
    <section class="content-card form-card text-center">
        <span class="value-badge">Validasi Amanah</span>
        <h2>📍 Validasi Lokasi</h2>

        <div class="islamic-message-box">
            <h3>Shidiq yang Dibuktikan</h3>
            <p>
                Sistem akan memeriksa lokasi sebagai bentuk ikhtiar menjaga kejujuran
                dalam proses absensi.
            </p>
        </div>

        <p id="status">Mengambil lokasi GPS...</p>

        <form id="gpsForm">
            <input type="hidden" name="token" id="token" value="<%= token %>">
            <input type="hidden" name="latitude" id="latitude">
            <input type="hidden" name="longitude" id="longitude">

            <button type="button" class="btn-primary" onclick="sendLocation()">
                Coba Lagi
            </button>
        </form>
    </section>
</main>

<script>
    const statusText = document.getElementById('status');

    function sendLocation() {
        if (!navigator.geolocation) {
            statusText.innerText = 'Browser tidak mendukung GPS.';
            return;
        }

        statusText.innerText = 'Mengambil lokasi GPS... Maksimal 1 menit.';

        navigator.geolocation.getCurrentPosition(
            function(position) {
                document.getElementById('latitude').value = position.coords.latitude;
                document.getElementById('longitude').value = position.coords.longitude;

                submitLocation();
            },
            function(error) {
                if (error.code === 1) {
                    statusText.innerText = 'Akses lokasi ditolak. Izinkan lokasi di browser.';
                } else if (error.code === 2) {
                    statusText.innerText = 'Lokasi tidak tersedia. Pastikan GPS aktif.';
                } else if (error.code === 3) {
                    statusText.innerText = 'Waktu mengambil lokasi habis. Coba lagi.';
                } else {
                    statusText.innerText = 'Gagal mengambil lokasi.';
                }
            },
            {
                enableHighAccuracy: false,
                timeout: 60000,
                maximumAge: 0
            }
        );
    }

    async function submitLocation() {
        const token = document.getElementById('token').value;
        const latitude = document.getElementById('latitude').value;
        const longitude = document.getElementById('longitude').value;

        statusText.innerText = 'Mengirim data absensi...';

        try {
            const response = await fetch('/api/absen-gps', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify({
                    token,
                    latitude,
                    longitude
                })
            });

            const data = await response.json();

            window.location.href =
                `/scan-success?success=${data.success}&message=${encodeURIComponent(data.message)}`;
        } catch (error) {
            statusText.innerText = 'Gagal mengirim data absensi.';
        }
    }

    sendLocation();
</script>

</body>
</html>