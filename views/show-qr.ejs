<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>QR Absensi | Al-Muraqabah</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>

<%- include('partials/navbar') %>

<main class="main-content">
    <section class="content-card qr-page-card">
        <div class="qr-header">
            <div>
                <span class="value-badge">QR Amanah</span>
                <h2>📱 QR Absensi</h2>
                <p>QR ini menjadi sarana menjaga kejujuran kehadiran mahasiswa.</p>
            </div>

            <a href="/dashboard" class="btn-secondary">Kembali ke Dashboard</a>
        </div>

        <div class="qr-session-info">
            <div>
                <span>Judul Pertemuan</span>
                <strong><%= session.judul %></strong>
            </div>

            <div>
                <span>Status</span>
                <strong>Aktif</strong>
            </div>

            <div>
                <span>Berakhir</span>
                <strong><%= session.expires_at %></strong>
            </div>
        </div>

        <div class="islamic-message-box">
            <h3>Dari Iman ke Aksi</h3>
            <p>
                Teknologi hanya alat. Nilai utamanya adalah kesadaran untuk hadir
                dengan jujur, tanpa titip absen, dan bertanggung jawab terhadap ilmu.
            </p>
        </div>

        <div class="qr-display-box">
            <div id="qr-loading" class="qr-loading">Membuat QR Code...</div>
            <img id="qr-image" src="" alt="QR Code Absensi" style="display: none;">
        </div>

        <div class="qr-footer-info">
            <p>QR otomatis diperbarui setiap <strong>30 detik</strong>.</p>
            <p id="qr-status">Menunggu QR aktif...</p>
        </div>
    </section>
</main>

<script>
    const sessionId = '<%= session.id %>';
    const qrImage = document.getElementById('qr-image');
    const qrLoading = document.getElementById('qr-loading');
    const qrStatus = document.getElementById('qr-status');

    async function loadQrCode() {
        try {
            qrLoading.style.display = 'block';
            qrLoading.innerText = 'Membuat QR Code...';
            qrStatus.innerText = 'Memperbarui QR Code...';

            const response = await fetch(`/api/qr-token/${sessionId}`, {
                method: 'GET',
                headers: { 'Accept': 'application/json' }
            });

            const data = await response.json();

            if (!response.ok || !data.success) {
                qrImage.style.display = 'none';
                qrLoading.style.display = 'block';
                qrLoading.innerText = data.message || 'Gagal membuat QR Code.';
                qrStatus.innerText = 'QR tidak aktif.';
                return;
            }

            qrImage.src = data.qrCode;
            qrImage.style.display = 'block';
            qrLoading.style.display = 'none';
            qrStatus.innerText = 'QR aktif. Silakan scan menggunakan akun mahasiswa.';
        } catch (error) {
            qrImage.style.display = 'none';
            qrLoading.style.display = 'block';
            qrLoading.innerText = 'Gagal memuat QR Code.';
            qrStatus.innerText = 'Terjadi kesalahan koneksi.';
        }
    }

    loadQrCode();
    setInterval(loadQrCode, 30000);
</script>

</body>
</html>